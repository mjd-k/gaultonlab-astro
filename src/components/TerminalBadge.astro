---
interface Props {
  path?: string;
}

const { path } = Astro.props;
---

<div
  class="mb-3 inline-flex items-center gap-2 rounded-full border border-border/40 bg-muted/20 px-3.5 py-1.5 font-firacode text-xs sm:text-sm"
>
  <span class="relative flex h-2 w-2">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-60"></span>
    <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
  </span>
  <span class="text-accent">~</span>
  /gaultonlab{path ? `/${path.toLowerCase()}` : ""}
  <span class="opacity-40">$</span>
</div>
