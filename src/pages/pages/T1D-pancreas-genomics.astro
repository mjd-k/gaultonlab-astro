---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import TerminalBadge from "@/components/TerminalBadge.astro";
import { SITE } from "@/config";

const tools = [
  { label: "Single Cell Browser", icon: "dna", url: "http://tools.cmdga.org/t1d-whole-pancreas" },
  { label: "Single Cell Spatial Browser", icon: "map", url: "http://tools.cmdga.org/npod_spatial" },
  { label: "Differential Expression Browser", icon: "chart", url: "https://tools.cmdga.org/t1d-pancreas-expression-browser" },
  { label: "scRNA map of Pancreas", icon: "download", url: "https://npod-data-download.s3.us-west-2.amazonaws.com/072424_npod_RNA.rds" },
  { label: "scATAC map of Pancreas", icon: "download", url: "https://npod-data-download.s3.us-west-2.amazonaws.com/120125_npod_ATAC.rds" },
  { label: "User Manual", icon: "book", url: "http://tools.cmdga.org/user-manual" },
];
---

<Layout title={`T1D Pancreas Genomics | ${SITE.title}`} description="Single-cell multiome and spatial profiling reveals pancreas cell type-specific gene regulatory programs driving type 1 diabetes progression.">
  <Header />
  <main id="main-content" class="app-layout pb-16">
    <TerminalBadge path="resources/t1d-pancreas-genomics" />
    <a href="/resources" class="mt-1 mb-6 flex items-center gap-1 text-sm text-foreground/50 transition-colors hover:text-accent">
      <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
      Back to Resources
    </a>

    <div class="mb-10 rounded-2xl border border-border/25 bg-muted/10 p-6 text-center sm:p-8">
      <h1 class="text-xl font-semibold sm:text-2xl">Single-cell multiome and spatial profiling reveals pancreas cell type-specific gene regulatory programs driving type 1 diabetes progression</h1>
    </div>

    <section>
      <div class="mb-6 flex items-center gap-3">
        <h2 class="text-sm font-bold tracking-widest uppercase">Tools & Data</h2>
        <div class="h-px flex-1 bg-border/20" />
      </div>

      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map(tool => (
          <li class="tool-card group/card relative rounded-2xl border border-border/25 bg-muted/10 backdrop-blur-sm transition-[border-color,background-color,box-shadow,transform] duration-300 ease-out motion-reduce:transform-none motion-reduce:transition-none hover:-translate-y-0.5 hover:border-accent/40 hover:bg-accent/5 hover:shadow-lg hover:shadow-accent/10">
            <div class="tool-glow pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 motion-reduce:transition-none group-hover/card:opacity-100" aria-hidden="true" />
            <a href={tool.url} target="_blank" rel="noopener noreferrer" class="relative z-5 flex flex-col items-center p-5 text-center">
              <div class="mb-3 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/5">
                <svg class="size-6 text-accent/60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  {tool.icon === "dna" && <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />}
                  {tool.icon === "map" && <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />}
                  {tool.icon === "chart" && <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />}
                  {tool.icon === "download" && <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />}
                  {tool.icon === "book" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />}
                </svg>
              </div>
              <span class="text-sm font-semibold text-foreground transition-colors duration-200 group-hover/card:text-accent">{tool.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12 rounded-2xl border border-border/25 bg-muted/10 p-5 sm:p-6">
      <h2 class="mb-3 text-sm font-bold tracking-widest uppercase">Supplementary Material</h2>
      <p class="text-sm leading-relaxed text-foreground/70">
        Supplementary data for Melton et al:
        <a href="https://www.dropbox.com/scl/fo/tuj93boiza01avg5bt374/AJ7tcEJOJA9Q8nDI88tVnLw?rlkey=psl7xpc87qk21klmk75mapdxv&st=5surh1tg&dl=0" target="_blank" rel="noopener noreferrer" class="ml-1 font-medium text-accent hover:underline">
          Download
          <svg class="mb-0.5 ml-0.5 inline size-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        </a>
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .tool-card { contain: paint; }
  .tool-glow {
    background: radial-gradient(350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), color-mix(in oklab, var(--accent) 8%, transparent) 0%, color-mix(in oklab, var(--accent) 4%, transparent) 30%, color-mix(in oklab, var(--accent) 0.8%, transparent) 60%, transparent 80%);
    will-change: opacity;
  }
  @media (prefers-reduced-motion: reduce) { .tool-glow { background: none; } }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>(".tool-card").forEach(card => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
      });
    });
  });
</script>
