---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import TerminalBadge from "@/components/TerminalBadge.astro";
import { SITE } from "@/config";

const supplementary = [
  "Liver cell type-specific cCREs",
  "Liver cell type-specific chromatin states",
  "Liver cell type-specific TF gene regulatory networks",
  "Differential association results for molecular features in liver cell types",
  "Summary statistics for liver cell type QTLs",
];
---

<Layout title={`Liver Multiome | ${SITE.title}`} description="Single cell multiomics reveals drivers of metabolic dysfunction-associated steatohepatitis.">
  <Header />
  <main id="main-content" class="app-layout pb-16">
    <TerminalBadge path="resources/liver-multiome" />
    <a href={`${import.meta.env.BASE_URL}resources/`} class="mt-1 mb-6 flex items-center gap-1 text-sm text-foreground/50 transition-colors hover:text-accent">
      <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
      Back to Resources
    </a>

    <div class="mb-10 rounded-2xl border border-border/25 bg-muted/10 p-6 text-center sm:p-8">
      <h1 class="text-xl font-semibold sm:text-2xl">Single cell multiomics reveals drivers of metabolic dysfunction-associated steatohepatitis</h1>
    </div>

    <section>
      <div class="mb-6 flex items-center gap-3">
        <h2 class="text-sm font-bold tracking-widest uppercase">Supplemental Material</h2>
        <div class="h-px flex-1 bg-border/20" />
      </div>

      <ul class="space-y-2">
        {supplementary.map(item => (
          <li class="rounded-xl border border-border/25 bg-muted/10 px-5 py-3 text-sm text-foreground/70">
            {item}
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12 rounded-2xl border border-border/25 bg-muted/10 p-5 sm:p-6">
      <h2 class="mb-3 text-sm font-bold tracking-widest uppercase">Citation</h2>
      <p class="text-sm leading-relaxed text-foreground/70">
        Elison et al. Single cell multiomics reveals drivers of metabolic dysfunction-associated steatohepatitis. <em>Submitted.</em>
      </p>
    </section>
  </main>
  <Footer />
</Layout>
