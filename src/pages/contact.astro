---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import TerminalBadge from "@/components/TerminalBadge.astro";
import { SITE } from "@/config";
---

<Layout title={`Contact | ${SITE.title}`} description="Contact information and location for the Gaulton Lab at UC San Diego.">
  <Header />
  <main id="main-content" class="app-layout pb-16">
    <TerminalBadge path="contact" />
    <h1 class="text-2xl font-semibold sm:text-3xl mb-8">Contact</h1>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <!-- Location -->
      <div class="contact-card group/card relative rounded-2xl border border-border/25 bg-muted/10 backdrop-blur-sm overflow-hidden transition-[border-color,background-color,box-shadow,transform] duration-300 ease-out motion-reduce:transform-none motion-reduce:transition-none hover:-translate-y-0.5 hover:border-accent/40 hover:bg-accent/5 hover:shadow-lg hover:shadow-accent/10">
        <div class="contact-glow pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 motion-reduce:transition-none group-hover/card:opacity-100" aria-hidden="true" />
        <div class="relative z-5 p-6">
          <div class="mb-4 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/5">
            <svg class="size-6 text-accent/70" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
            </svg>
          </div>
          <h2 class="mb-2 text-lg font-semibold text-foreground">Location</h2>
          <p class="text-sm leading-relaxed text-foreground/70">
            Cellular and Molecular Medicine East<br />
            Room 1088D<br />
            La Jolla, CA 92161
          </p>
          <p class="mt-2 text-xs text-foreground/50">
            (Entrance is off Gilman Dr. across from Leichtag)
          </p>
        </div>
      </div>

      <!-- Email -->
      <div class="contact-card group/card relative rounded-2xl border border-border/25 bg-muted/10 backdrop-blur-sm overflow-hidden transition-[border-color,background-color,box-shadow,transform] duration-300 ease-out motion-reduce:transform-none motion-reduce:transition-none hover:-translate-y-0.5 hover:border-accent/40 hover:bg-accent/5 hover:shadow-lg hover:shadow-accent/10">
        <div class="contact-glow pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 motion-reduce:transition-none group-hover/card:opacity-100" aria-hidden="true" />
        <div class="relative z-5 p-6">
          <div class="mb-4 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/5">
            <svg class="size-6 text-accent/70" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h2 class="mb-2 text-lg font-semibold text-foreground">Email</h2>
          <a href="mailto:kgaulton@ucsd.edu" class="text-sm text-accent hover:underline">kgaulton@ucsd.edu</a>
        </div>
      </div>
    </div>

    <!-- Map -->
    <section class="mt-6">
      <div class="overflow-hidden rounded-2xl border border-border/25">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3351.0!2d-117.2340!3d32.8755!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80dc06c4414bb88d%3A0x97741ae2ff2bd5b1!2sCellular%20and%20Molecular%20Medicine%20East%2C%20La%20Jolla%2C%20CA%2092093!5e0!3m2!1sen!2sus!4v1"
          width="100%"
          height="350"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Gaulton Lab location — Cellular and Molecular Medicine East, UCSD"
        ></iframe>
      </div>
    </section>

    <!-- Recruitment -->
    <section class="mt-6">
      <div class="rounded-2xl border border-border/25 bg-muted/10 backdrop-blur-sm p-6">
        <h2 class="mb-2 text-lg font-semibold text-foreground">Join the Lab</h2>
        <p class="text-sm leading-relaxed text-foreground/70">
          For those interested in postdoctoral or other positions in the lab, please email with a description of research interests and a current CV.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-card {
    contain: paint;
  }

  .contact-glow {
    background: radial-gradient(
      350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      color-mix(in oklab, var(--accent) 8%, transparent) 0%,
      color-mix(in oklab, var(--accent) 4%, transparent) 30%,
      color-mix(in oklab, var(--accent) 0.8%, transparent) 60%,
      transparent 80%
    );
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-glow {
      background: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>(".contact-card").forEach(card => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
      });
    });
  });
</script>
