---

<Layout title={`People | ${SITE.title}`} description="Meet the researchers, students, and staff of the Gaulton Lab at UC San Diego.">
  <Header />
  <main id="main-content" class="app-layout pb-16">
    <TerminalBadge path="people" />
    <h1 class="text-2xl font-semibold sm:text-3xl mb-8">People</h1>

    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {members.map(member => (
        <li
          class:list={[
            "person-card group/card relative rounded-2xl",
            "border border-border/25 bg-muted/10 backdrop-blur-sm",
            "transition-[border-color,background-color,box-shadow,transform] duration-300 ease-out",
            "motion-reduce:transform-none motion-reduce:transition-none",
            "hover:-translate-y-0.5 hover:border-accent/40 hover:bg-accent/5",
            "hover:shadow-lg hover:shadow-accent/10",
          ]}
        >
          <div class="person-glow pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 motion-reduce:transition-none group-hover/card:opacity-100" aria-hidden="true" />
          <div class="relative z-5 p-5">
            <div class="mb-4 flex justify-center">
              <Image
                src={member.photo}
                alt={member.name}
                class="size-28 rounded-full object-cover ring-2 ring-border/20 transition-all duration-300 group-hover/card:ring-accent/40"
                width={112}
                height={112}
              />
            </div>
            <div class="mb-1 text-center text-lg font-semibold text-foreground transition-colors duration-200 group-hover/card:text-accent">
              {member.name}
            </div>
            <div class="text-center text-sm font-medium text-accent/80">
              {member.title}
            </div>
            <ul class="mt-3 space-y-1 text-center">
              {member.education.map(edu => (
                <li class="text-xs leading-relaxed text-foreground/55">{edu}</li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ul>

    <section class="mt-16">
      <div class="mb-6 flex items-center gap-3">
        <h2 class="text-sm font-bold tracking-widest uppercase">Lab Alumni</h2>
        <div class="h-px flex-1 bg-border/20" />
      </div>
      {alumni.map(group => (
        <div class="mb-6">
          <h3 class="mb-2 text-sm font-semibold text-foreground/80">{group.category}</h3>
          <ul class="grid grid-cols-1 gap-x-8 gap-y-1.5 sm:grid-cols-2 lg:grid-cols-3">
            {group.members.map(member => (
              <li class="text-sm text-foreground/55">{member}</li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .person-card {
    contain: paint;
  }

  .person-glow {
    background: radial-gradient(
      350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      color-mix(in oklab, var(--accent) 8%, transparent) 0%,
      color-mix(in oklab, var(--accent) 4%, transparent) 30%,
      color-mix(in oklab, var(--accent) 0.8%, transparent) 60%,
      transparent 80%
    );
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .person-glow {
      background: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>(".person-card").forEach(card => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
      });
    });
  });
</script>
